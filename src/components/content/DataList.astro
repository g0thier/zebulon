---
import { renderInlineMarkdown, type DataList, type DataListEntry, type LinkItem } from "../../data/blog-articles";

type Props = {
  list: DataList;
};

const { list } = Astro.props;
const showHeading = !["liste", "articles"].includes(list.label.toLowerCase());
const isBenefitsList = list.label.toLowerCase() === "bénéfices" || list.label.toLowerCase() === "benefices";
const isActionList = list.label.toLowerCase() === "site";
const labelClass = `data-list--${list.label
  .toLowerCase()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "")
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/^-|-$/g, "")}`;

function isEntry(item: string | LinkItem | DataListEntry): item is DataListEntry {
  return typeof item === "object" && "value" in item && "depth" in item;
}

function entryValue(item: string | LinkItem | DataListEntry): string | LinkItem {
  return isEntry(item) ? item.value : item;
}

function entryDepth(item: string | LinkItem | DataListEntry): number {
  return isEntry(item) ? item.depth : 0;
}

function isLink(item: string | LinkItem): item is LinkItem {
  return typeof item !== "string";
}
---

{
  list.items.length > 0 && (
    <div class:list={["data-list", labelClass]}>
      {showHeading && (isBenefitsList || isActionList ? <h2>{list.label}</h2> : <h3>{list.label}</h3>)}
      <ul>
        {list.items.map((item) => {
          const value = entryValue(item);
          const depth = entryDepth(item);
          return (
          <li class:list={[depth > 0 && `data-list__item--depth-${Math.min(depth, 3)}`]}>
            {isLink(value) ? (
              <a class:list={[isActionList && "cta-link", isActionList && "cta-link--secondary", isActionList && "legal-action-link"]} href={value.href}>{value.label}</a>
            ) : (
              <span set:html={renderInlineMarkdown(value)} />
            )}
          </li>
          );
        })}
      </ul>
    </div>
  )
}
