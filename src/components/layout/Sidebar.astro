---
import { sidebarSections } from "../../data/site-shell";
---

<aside class="sidebar" aria-label="Repères utiles">
  {sidebarSections.map((section) => (
    <section>
      <h2>{section.label}</h2>
      <ul>
        {section.items?.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </section>
  ))}
</aside>
