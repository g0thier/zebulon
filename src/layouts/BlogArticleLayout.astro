---
import CtaLink from "../components/ui/CtaLink.astro";
import StatusBadge from "../components/ui/StatusBadge.astro";
import type { Article } from "../data/blog-articles";
import SiteLayout from "./SiteLayout.astro";

type Props = {
  article: Article;
};

const { article } = Astro.props;
---

<SiteLayout title={article.data.title} description={article.data.subtitle}>
  <article>
    <section class="hero">
      <div class="hero__badges">
        <StatusBadge label={article.data.category} variant="section" />
        <StatusBadge label={article.data.status} />
      </div>
      <h1>{article.data.title}</h1>
      {article.data.subtitle && <p class="hero__intro">{article.data.subtitle}</p>}
      {article.data.questionCount > 0 && <p>{article.data.questionCount} questions</p>}
      {article.data.cta && <div class="hero__actions"><CtaLink cta={article.data.cta} /></div>}
    </section>

    <slot />
  </article>
</SiteLayout>
