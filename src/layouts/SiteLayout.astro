---
import SiteFooter from "../components/layout/SiteFooter.astro";
import SiteHeader from "../components/layout/SiteHeader.astro";
import Sidebar from "../components/layout/Sidebar.astro";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  showSidebar?: boolean;
};

const { title = "zzzbre", description, showSidebar = true } = Astro.props;
const pageTitle = title === "zzzbre" ? title : `${title} | zzzbre`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <SiteHeader />
    <main class:list={["site-main", showSidebar && "site-main--with-sidebar"]}>
      <div class="page-content">
        <slot />
      </div>
      {showSidebar && <Sidebar />}
    </main>
    <SiteFooter />
  </body>
</html>
