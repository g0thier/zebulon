---
import ContentBlock from "../components/content/ContentBlock.astro";
import { editorialPages, motivationArticleLinks } from "../data/editorial-pages";
import { type Card, type ContentBlock as ContentBlockType, type EditorialPage } from "../data/source-map";
import EditorialPageLayout from "../layouts/EditorialPageLayout.astro";

export function getStaticPaths() {
  return editorialPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

type Props = {
  page: EditorialPage;
};

const { page } = Astro.props;
const isLeadershipCategory = page.slug === "ressources/blog/categories/leadership-et-engagement";
const heroSectionLabel = page.slug === "clients/etudes-de-cas" ? "Étude de cas" : page.section;
const renderedBlocks = prepareBlocks(page);

function prepareBlocks(page: EditorialPage): ContentBlockType[] {
  const blocks = page.blocks.filter((block) => !(page.slug === "contact" && block.heading === "Créer un compte"));

  if (page.slug === "contact") {
    return groupContactBlocks(blocks, page);
  }

  if (page.slug === "produit/securite" || page.slug === "tarifs") {
    return groupFaqBlocks(blocks, page);
  }

  return blocks;
}

function groupFaqBlocks(blocks: ContentBlockType[], page: EditorialPage): ContentBlockType[] {
  const grouped: ContentBlockType[] = [];
  let faqCards: Card[] = [];

  const flushFaq = () => {
    if (!faqCards.length) return;
    grouped.push({
      heading: "FAQ",
      kind: "cards",
      text: [],
      fields: [],
      lists: [],
      cards: faqCards,
      ctas: [],
      sourcePath: page.sourcePath,
    });
    faqCards = [];
  };

  for (const block of blocks) {
    if (block.heading === "FAQ" && !block.text.length && !block.fields.length && !block.lists.length && !block.cards.length && !block.ctas.length) {
      continue;
    }

    if (block.kind === "faq" && block.heading) {
      faqCards.push({
        title: block.heading,
        text: block.text.join(" "),
        fields: [],
        lists: [],
        sourcePath: block.sourcePath,
      });
      continue;
    }

    flushFaq();
    grouped.push(block);
  }

  flushFaq();
  return grouped;
}

function groupContactBlocks(blocks: ContentBlockType[], page: EditorialPage): ContentBlockType[] {
  const grouped: ContentBlockType[] = [];
  let pendingCards: Card[] = [];

  const flushCards = () => {
    if (!pendingCards.length) return;
    grouped.push({
      kind: "cards",
      text: [],
      fields: [],
      lists: [],
      cards: pendingCards,
      ctas: [],
      sourcePath: page.sourcePath,
    });
    pendingCards = [];
  };

  for (const block of blocks) {
    if (block.heading === "Nous contacter") {
      flushCards();
      grouped.push(block);
      continue;
    }

    if (block.heading === "Adresse") {
      flushCards();
      grouped.push(block);
      continue;
    }

    flushCards();
    grouped.push(block);
  }

  flushCards();
  return grouped;
}
---

<EditorialPageLayout page={page} heroSectionLabel={heroSectionLabel}>
  {renderedBlocks.map((block, index) => <ContentBlock block={block} pageSlug={page.slug} blockIndex={index} />)}

  {
    isLeadershipCategory && motivationArticleLinks.length > 0 && (
      <section class="content-block">
        <h2>Série Motivation</h2>
        <div class="card-grid">
          {motivationArticleLinks.map((article) => (
            <a class="editorial-card" href={article.href}>
              <h3>{article.label}</h3>
            </a>
          ))}
        </div>
      </section>
    )
  }
</EditorialPageLayout>
