---
import ContentBlock from "../components/content/ContentBlock.astro";
import productScreenshot from "../assets/Capture.png";
import { homePage } from "../data/editorial-pages";
import EditorialPageLayout from "../layouts/EditorialPageLayout.astro";
---

<EditorialPageLayout page={homePage} showSectionBadge={false}>
  <figure class="product-screenshot product-screenshot--home product-screenshot--unframed">
    <img src={productScreenshot.src} alt="Capture d'écran du produit zzzbre" />
  </figure>

  {homePage.blocks.map((block, index) => <ContentBlock block={block} pageSlug="" blockIndex={index} />)}
</EditorialPageLayout>
