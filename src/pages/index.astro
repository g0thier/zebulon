---
import ContentBlock from "../components/content/ContentBlock.astro";
import CtaLink from "../components/ui/CtaLink.astro";
import StatusBadge from "../components/ui/StatusBadge.astro";
import productScreenshot from "../assets/Capture.png";
import { homePage } from "../data/editorial-pages";
import { renderInlineMarkdown } from "../data/source-map";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title={homePage.title} description={homePage.intro}>
  <section class="hero">
    <StatusBadge label={homePage.status} />
    <h1>{homePage.title}</h1>
    {homePage.subtitle && <p class="hero__intro">{homePage.subtitle}</p>}
    {homePage.intro && <p set:html={renderInlineMarkdown(homePage.intro, homePage.sourcePath)} />}
    {
      homePage.visual && (
        <figure class="hero__visual">
          <img src={homePage.visual.src} alt={homePage.visual.label} />
        </figure>
      )
    }
    {
      homePage.ctas.length > 0 && (
        <div class="hero__actions">
          {homePage.ctas.map((cta) => <CtaLink cta={cta} />)}
        </div>
      )
    }
  </section>

  <figure class="product-screenshot product-screenshot--home">
    <img src={productScreenshot.src} alt="Capture d'écran du produit zzzbre" />
  </figure>

  {homePage.blocks.map((block, index) => <ContentBlock block={block} pageSlug="" blockIndex={index} />)}
</SiteLayout>
